DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DYNAMO_TABLE=shift-state
PORT=3000

# Local dev only — points the AWS SDK at DynamoDB Local (set by docker-compose).
# Leave unset in production so the SDK talks to real AWS.
DYNAMO_ENDPOINT=
OFFICER_ROLE_ID=
SHIFT_TIMEZONE=America/New_York

# Deploy-only — used by scripts/deploy.mjs to push the image to ECR and
# update the Lambda function. Not read at runtime.
AWS_REGION=us-east-2
ECR_REPO=machine-spirit
LAMBDA_FUNCTION=machine-spirit-container
